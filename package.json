{
  "name": "@eq-solutions/roles",
  "version": "2.5.2",
  "private": false,
  "license": "UNLICENSED",
  "author": "CDC Solutions Pty Ltd",
  "description": "Canonical EQ role model — the 6-tier role enum (manager / supervisor / employee / apprentice / labour_hire / subcontractor), the is_platform_admin override, and the permission matrix. Single source of truth across every EQ surface (Shell, Field, Service, Cards, Quotes). Outputs typed TS + resolved JSON from one JSON source.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eq-solutions/eq-roles.git"
  },
  "keywords": ["eq-solutions", "rbac", "roles", "permissions", "authorization"],
  "main": "roles.js",
  "types": "roles.ts",
  "exports": {
    ".": { "types": "./roles.ts", "default": "./roles.js" },
    "./roles.js": "./roles.js",
    "./roles.ts": "./roles.ts",
    "./roles.json": "./roles.json",
    "./package.json": "./package.json",
    "./admin": { "types": "./roles/admin.ts", "default": "./roles/admin.js" },
    "./audit": { "types": "./roles/audit.ts", "default": "./roles/audit.js" },
    "./entity": { "types": "./roles/entity.ts", "default": "./roles/entity.js" },
    "./intake": { "types": "./roles/intake.ts", "default": "./roles/intake.js" },
    "./equipment": { "types": "./roles/equipment.ts", "default": "./roles/equipment.js" },
    "./reports": { "types": "./roles/reports.ts", "default": "./roles/reports.js" },
    "./cards": { "types": "./roles/cards.ts", "default": "./roles/cards.js" },
    "./service": { "types": "./roles/service.ts", "default": "./roles/service.js" },
    "./field": { "types": "./roles/field.ts", "default": "./roles/field.js" },
    "./quotes": { "types": "./roles/quotes.ts", "default": "./roles/quotes.js" },
    "./ops": { "types": "./roles/ops.ts", "default": "./roles/ops.js" }
  },
  "files": ["roles/", "roles.js", "roles.ts", "roles.json", "roles.dart", "build.mjs", "README.md"],
  "scripts": {
    "build": "node build.mjs",
    "test": "node --import tsx/esm --test roles.test.ts roles.dist.test.ts executive-scaffold.test.ts",
    "prepublishOnly": "node build.mjs && npm test"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  },
  "publishConfig": { "access": "restricted" },
  "engines": { "node": ">=18" }
}
